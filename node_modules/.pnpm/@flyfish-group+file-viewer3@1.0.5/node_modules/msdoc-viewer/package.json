{
  "name": "msdoc-viewer",
  "version": "0.2.0",
  "description": "Strict TypeScript MS-DOC (.doc) reader and HTML/CSS renderer with optional Web Worker support.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "default": "./dist/worker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "doc",
    "ms-doc",
    "ole",
    "cfb",
    "word",
    "viewer",
    "html"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "npm run build && node ./test/smoke.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run smoke"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wybaby168/msdoc-viewer.git"
  },
  "homepage": "https://github.com/wybaby168/msdoc-viewer#readme",
  "bugs": {
    "url": "https://github.com/wybaby168/msdoc-viewer/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
